# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/beauty_store

# ─── Cache / Queue ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth & Cookies ──────────────────────────────────────────────────────────
JWT_SECRET=
COOKIE_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
STORE_CORS=http://localhost:3000,https://your-storefront.com
ADMIN_CORS=http://localhost:9000,https://your-admin.com
AUTH_CORS=http://localhost:3000,http://localhost:9000

# ─── Search ──────────────────────────────────────────────────────────────────
# MEILISEARCH_HOST: URL of your MeiliSearch instance
#   Local dev: http://localhost:7700
#   Production: https://your-instance.meilisearch.io
MEILISEARCH_HOST=http://localhost:7700

# MEILISEARCH_API_KEY: Master key (backend only — NEVER expose to frontend)
#   Local dev: any string e.g. "masterKey"
#   Production: a strong random secret (min 16 chars)
#   The backend uses this to manage indexes and create restricted search-only keys.
#   The frontend receives a scoped search-only key via GET /store/search/key.
MEILISEARCH_API_KEY=

# ─── Payments ────────────────────────────────────────────────────────────────
STRIPE_API_KEY=

# bKash PGW v1.2 Tokenized Checkout
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Nagad Direct API
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=

# ─── Media / CDN ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=ecom-media
R2_PUBLIC_URL=https://media.yourdomain.com

DB_NAME=medusa-ecom-api

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@glownest.com
BREVO_SENDER_NAME=GlowNest

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GlowNest" <noreply@glownest.com>

# ─── SMS ─────────────────────────────────────────────────────────────────────
SMS_ENABLED=true
NETSMSBD_API_KEY=your_netsmsbd_api_key
NETSMSBD_SENDER_ID=GlowNest

# ─── Admin Notifications ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@glownest.com
ADMIN_PHONE=01XXXXXXXXX